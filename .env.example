# ─── Gemini API (solo en servidor — NUNCA en el cliente) ───────────────────────
# Esta variable se configura en Vercel > Settings > Environment Variables
# NO crear un .env.local con esta variable (quedaría en el bundle del cliente)
GEMINI_API_KEY=AIzaSy...

# ─── n8n Webhooks (público — OK en el cliente con prefijo VITE_) ────────────────
# Webhook del Paso 1: ContactModal → n8n envía email con el lead inicial
VITE_N8N_CONTACTO_URL=https://tu-n8n.tudominio.com/webhook/mindwave-contacto

# Webhook del Paso 2: DiscoveryPage → n8n envía email con el brief completo
VITE_N8N_BRIEF_URL=https://tu-n8n.tudominio.com/webhook/mindwave-brief
